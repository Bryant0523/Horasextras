{
  "name": "rook-app",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.rook.app",
    "productName": "Rook",
    "files": [
      "main.js",
      "renderer/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "/renderer/image/Logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}